{
  "$schema": "http://json-schema.org/draft-07/schema",
  "title": "AccelMark Environment Info",
  "type": "object",
  "required": ["collected_at","accelerators","cpu","system_memory_gb","pcie_generation","kernel_version","runtime_version"],
  "additionalProperties": false,
  "properties": {
    "collected_at": { "type": "string", "format": "date-time" },
    "accelerators": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["index","name","memory_gb","driver_version"],
        "additionalProperties": true,
        "properties": {
          "index": { "type": "integer" },
          "name": { "type": "string" },
          "vendor": { "type": "string", "description": "Chip vendor, e.g. 'NVIDIA', 'AMD', 'Huawei', 'Apple'" },
          "memory_gb": { "type": ["number","null"], "minimum": 0 },
          "driver_version": { "type": "string" },
          "firmware_version": { "type": ["string","null"] },
          "compute_capability": {
            "type": ["string","null"],
            "description": "NVIDIA compute capability, e.g. '8.0'. Null for non-NVIDIA accelerators."
          },
          "supports_bf16": {
            "type": ["boolean","null"],
            "description": "Whether the accelerator natively supports BF16 compute. Set by collect_env.py."
          }
        }
      }
    },
    "accelerator_topology": { "type": ["string","null"] },
    "cpu": {
      "type": "object",
      "required": ["model","physical_cores","logical_cores","numa_nodes"],
      "additionalProperties": true,
      "properties": {
        "model": { "type": "string" },
        "physical_cores": { "type": "integer", "minimum": 1 },
        "logical_cores": { "type": "integer", "minimum": 1 },
        "numa_nodes": { "type": "integer", "minimum": 1 }
      }
    },
    "system_memory_gb": { "type": "number", "minimum": 0 },
    "pcie_generation": { "type": "string" },
    "cpu_accelerator_bandwidth_gbs": { "type": ["number","null"] },
    "network_interfaces": {
      "type": ["array","null"],
      "items": {
        "type": "object",
        "additionalProperties": true,
        "properties": {
          "name": { "type": "string" },
          "type": { "type": "string" },
          "bandwidth_gbps": { "type": ["number","null"] }
        }
      }
    },
    "os": { "type": "string", "description": "OS name and version, e.g. 'Ubuntu 22.04.4 LTS'" },
    "python_version": { "type": "string", "description": "Python version string, e.g. '3.10.18'" },
    "kernel_version": { "type": "string" },
    "runtime_version": { "type": "string" },
    "pytorch_version": {
      "type": ["string","null"],
      "description": "PyTorch version string, e.g. '2.5.1+cu121'"
    },
    "intra_node_interconnect": {
      "type": ["string","null"],
      "description": "Intra-node GPU interconnect detected, e.g. 'NVLink', or null if not detected"
    }
  }
}
