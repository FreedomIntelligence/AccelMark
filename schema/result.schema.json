{
  "$schema": "http://json-schema.org/draft-07/schema",
  "title": "AccelMark Result",
  "type": "object",
  "required": [
    "schema_version", "suite_id", "chip", "software",
    "model", "task", "metrics", "accuracy", "meta"
  ],
  "additionalProperties": false,
  "properties": {

    "schema_version": { "type": "string", "const": "1.0" },

    "suite_id": {
      "type": "string",
      "description": "Suite identifier. Standard suites: suite_A through suite_D. Mini suites: mini-nano, mini-mini, mini-standard, mini-pro. Custom: 'custom'."
    },

    "implementation_id": {
      "type": ["string", "null"],
      "description": "ID of the runner used to produce this result. Matches a folder name in runners/. Null or absent for results submitted before this feature was introduced.",
      "pattern": "^[a-z][a-z0-9]*_[a-z][a-z0-9_]*_[0-9a-f]{8}$"
    },

    "chip": {
      "type": "object",
      "required": ["name", "vendor", "count", "memory_gb_per_chip", "interconnect_intra_node"],
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string" },
        "vendor": {
          "type": "string",
          "enum": ["NVIDIA","AMD","Intel","Google","Huawei","Cambricon","Biren",
                   "Enflame","MetaX","Iluvatar","Apple","Qualcomm","Other"]
        },
        "count": { "type": "integer", "minimum": 1 },
        "memory_gb_per_chip": { "type": "number", "minimum": 0 },
        "interconnect_intra_node": { "type": "string" },
        "interconnect_inter_node": { "type": ["string", "null"] },
        "_count_note": {
          "type": ["string", "null"],
          "description": "Human-readable note about the chip count field. Only present for Suite E."
        }
      }
    },

    "software": {
      "type": "object",
      "required": ["framework","framework_version","driver_version","runtime_version","os","python_version"],
      "additionalProperties": false,
      "properties": {
        "framework": { "type": "string" },
        "framework_version": { "type": "string" },
        "driver_version": { "type": "string" },
        "runtime_version": { "type": "string" },
        "os": { "type": "string" },
        "python_version": { "type": "string" }
      }
    },

    "model": {
      "type": "object",
      "required": ["model_id","model_revision","architecture","parameter_count_b","precision","model_format"],
      "additionalProperties": false,
      "properties": {
        "model_id": { "type": "string" },
        "model_revision": { "type": "string" },
        "architecture": {
          "type": "string",
          "enum": ["dense","moe","vlm","linear_transformer","ttt","other"]
        },
        "parameter_count_b": { "type": "number", "minimum": 0 },
        "precision": {
          "type": "string",
          "description": "Effective compute precision used during this run. BF16 is standard; FP16 is used on hardware that does not support BF16 (e.g. V100, T4).",
          "enum": ["FP32","BF16","FP16","FP8","INT8","INT4","mixed"]
        },
        "model_format": { "type": "string" },
        "_note": {
          "type": ["string", "null"],
          "description": "Human-readable note about the model field. Only present for Suite C."
        }
      }
    },

    "task": {
      "type": "object",
      "required": ["num_runs"],
      "additionalProperties": false,
      "oneOf": [
        {"required": ["scenario"]},
        {"required": ["scenarios_run"]}
      ],
      "properties": {
        "scenario": {
          "type": "string",
          "enum": ["offline","online","interactive","multiturn","sustained","all"],
          "description": "Single scenario run. Required for single-scenario submissions."
        },
        "scenarios_run": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["offline","online","interactive","sustained"]
          },
          "description": "List of scenarios run. Used for suite-level submissions (--scenario all)."
        },
        "chip_counts_run": {
          "type": "array",
          "items": {"type": "integer"},
          "description": "Chip counts tested. Only present for Suite E submissions."
        },
        "precision_levels_run": {
          "type": "array",
          "items": {"type": "string"},
          "description": "Precision levels tested. Only present for Suite C submissions."
        },
        "parallelism_note": {
          "type": ["string", "null"],
          "description": "Human-readable note about parallelism strategy. Only present for Suite E submissions."
        },
        "num_runs": { "type": "integer", "minimum": 1 },
        "warmup_runs": {
          "type": "integer",
          "minimum": 0,
          "description": "Number of warmup runs. Optional for suite-level submissions."
        },
        "parallelism": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "tensor_parallel_size": { "type": ["integer","null"] },
            "pipeline_parallel_size": { "type": ["integer","null"] },
            "data_parallel_size": { "type": ["integer","null"] },
            "expert_parallel_size": { "type": ["integer","null"] }
          }
        },
        "extra_config": { "type": ["object","null"] }
      }
    },

    "metrics": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "offline": {
          "type": ["object","null"],
          "required": ["results_by_concurrency"],
          "properties": {
            "results_by_concurrency": {
              "type": "array",
              "description": "Offline throughput results at each client concurrency level.",
              "items": {
                "type": "object",
                "required": ["client_concurrency", "oom"],
                "additionalProperties": false,
                "properties": {
                  "client_concurrency": {
                    "type": "integer",
                    "minimum": 1,
                    "description": "Number of requests sent simultaneously. The inference engine handles internal batching automatically."
                  },
                  "throughput_tokens_per_sec": {
                    "type": ["number","null"],
                    "minimum": 0,
                    "description": "Total tokens per second including both input (prompt) and output tokens. Matches vLLM internal throughput metric."
                  },
                  "throughput_tokens_per_sec_per_chip": { "type": ["number","null"], "minimum": 0 },
                  "elapsed_seconds_median": {
                    "type": ["number","null"],
                    "description": "Median wall-clock time in seconds for one complete run at this client concurrency level."
                  },
                  "peak_memory_gb": { "type": ["number","null"], "minimum": 0 },
                  "power_watts_avg": { "type": ["number","null"] },
                  "power_watts_peak": { "type": ["number","null"] },
                  "oom": { "type": "boolean", "default": false },
                  "_concurrency_note": { "type": ["string","null"] }
                }
              }
            }
          }
        },
        "online": {
          "type": ["object","null"],
          "required": ["max_valid_qps","results_by_qps"],
          "properties": {
            "max_valid_qps": { "type": "number", "minimum": 0 },
            "results_by_qps": {
              "type": "array",
              "items": {
                "type": "object",
                "required": [
                  "target_qps","achieved_qps",
                  "ttft_ms_p50","ttft_ms_p90","ttft_ms_p99",
                  "tpot_ms_p50","tpot_ms_p90","tpot_ms_p99",
                  "sla_met"
                ],
                "additionalProperties": false,
                "properties": {
                  "target_qps": { "type": "number" },
                  "achieved_qps": { "type": ["number","null"] },
                  "ttft_ms_p50": { "type": "number" },
                  "ttft_ms_p90": { "type": "number" },
                  "ttft_ms_p99": { "type": "number" },
                  "tpot_ms_p50": { "type": "number" },
                  "tpot_ms_p90": { "type": "number" },
                  "tpot_ms_p99": { "type": "number" },
                  "elapsed_seconds_median": {
                    "type": ["number","null"],
                    "description": "Median wall-clock time in seconds for one complete run at this QPS level."
                  },
                  "sla_met": { "type": "boolean" }
                }
              }
            }
          }
        },
        "interactive": {
          "type": ["object","null"],
          "required": [
            "ttft_ms_p50","ttft_ms_p90","ttft_ms_p99",
            "tpot_ms_p50","tpot_ms_p90","tpot_ms_p99"
          ],
          "additionalProperties": false,
          "properties": {
            "ttft_ms_p50": { "type": "number" },
            "ttft_ms_p90": { "type": "number" },
            "ttft_ms_p99": { "type": "number" },
            "tpot_ms_p50": { "type": "number" },
            "tpot_ms_p90": { "type": "number" },
            "tpot_ms_p99": { "type": "number" },
            "peak_memory_gb": {
              "type": ["number","null"],
              "description": "Peak GPU memory in GB. Null if not measured."
            },
            "elapsed_seconds_median": {
              "type": ["number","null"],
              "description": "Median wall-clock time in seconds for one complete interactive run."
            }
          }
        },
        "training": {
          "type": ["object","null"],
          "required": ["tokens_per_sec","tokens_per_sec_per_chip","peak_memory_gb_per_chip"],
          "additionalProperties": false,
          "properties": {
            "tokens_per_sec": { "type": "number" },
            "tokens_per_sec_per_chip": { "type": "number" },
            "peak_memory_gb_per_chip": { "type": "number" },
            "power_watts_avg_per_chip": { "type": ["number","null"] },
            "mfu": { "type": ["number","null"], "minimum": 0, "maximum": 1 }
          }
        },
        "derived": {
          "type": "object",
          "description": "Auto-computed by validate_submission.py. Do not fill manually.",
          "additionalProperties": false,
          "properties": {
            "tokens_per_sec_per_watt": { "type": ["number","null"] },
            "tokens_per_sec_per_chip": { "type": ["number","null"] }
          }
        },
        "scaling": {
          "type": "object",
          "description": "Suite E scaling efficiency metrics",
          "properties": {
            "base_throughput_1x": {
              "type": ["number", "null"],
              "description": "Best throughput at 1x chip count (tok/s). Used as denominator for scaling efficiency."
            },
            "results_by_chip_count": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "chip_count": {"type": "integer"},
                  "best_throughput_tokens_per_sec": {"type": ["number", "null"]},
                  "throughput_tokens_per_sec_per_chip": {"type": ["number", "null"]},
                  "scaling_efficiency": {
                    "type": ["number", "null"],
                    "description": "N-chip throughput / (1-chip throughput × N). 1.0 = perfect linear scaling."
                  },
                  "results_by_concurrency": {"type": "array"},
                  "result_dir": {"type": "string"}
                }
              }
            }
          }
        },
        "quantization": {
          "type": "object",
          "description": "Suite C quantization efficiency metrics",
          "properties": {
            "results_by_precision": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "precision": {
                    "type": "string",
                    "enum": ["BF16", "INT8", "INT4"]
                  },
                  "best_throughput_tokens_per_sec": {
                    "type": ["number", "null"]
                  },
                  "accuracy_score": {
                    "type": ["number", "null"]
                  },
                  "quality_efficiency": {
                    "type": ["number", "null"],
                    "description": "throughput × accuracy_score. Higher = better speed/quality tradeoff."
                  },
                  "speedup_vs_bf16": {
                    "type": ["number", "null"],
                    "description": "Throughput ratio vs BF16 baseline. 1.5 = 50% faster than BF16."
                  },
                  "results_by_concurrency": {"type": "array"},
                  "result_dir": {"type": "string"}
                }
              }
            }
          }
        },
        "sustained": {
          "type": ["object", "null"],
          "description": "Time-based sustained load test metrics",
          "properties": {
            "target_qps":             { "type": ["number", "null"] },
            "duration_minutes":       { "type": ["number", "null"] },
            "sample_interval_seconds":{ "type": ["number", "null"] },
            "warmup_minutes":         { "type": ["number", "null"] },
            "sustained_throughput_tokens_per_sec": { "type": ["number", "null"] },
            "throttle_ratio":         { "type": ["number", "null"] },
            "throttle_onset_minute":  { "type": ["number", "null"] },
            "ttft_p99_drift_ms":      { "type": ["number", "null"] },
            "samples": {
              "type": ["array", "null"],
              "items": {
                "type": "object",
                "properties": {
                  "minute":                      { "type": ["number", "null"] },
                  "is_warmup":                   { "type": ["boolean", "null"] },
                  "throughput_tokens_per_sec":   { "type": ["number", "null"] },
                  "tokens_out":                  { "type": ["integer", "null"] },
                  "tokens_in":                   { "type": ["integer", "null"] },
                  "requests_completed":          { "type": ["integer", "null"] },
                  "ttft_ms_p50":                 { "type": ["number", "null"] },
                  "ttft_ms_p99":                 { "type": ["number", "null"] }
                }
              }
            }
          }
        }
      }
    },

    "accuracy": {
      "type": "object",
      "required": ["subset_score","baseline_delta","valid"],
      "additionalProperties": false,
      "properties": {
        "subset_score": { "type": ["number","null"], "minimum": 0, "maximum": 1 },
        "baseline_delta": { "type": ["number","null"] },
        "valid": { "type": "boolean" },
        "framework": {
          "type": ["string","null"],
          "description": "Framework used for accuracy check."
        },
        "precision": {
          "type": ["string","null"],
          "description": "Precision used for accuracy check."
        },
        "notes": { "type": ["string","null"] }
      }
    },

    "meta": {
      "type": "object",
      "required": ["submitted_by","submission_type","date","reproduce_script","env_info_file","log_file"],
      "additionalProperties": false,
      "properties": {
        "submitted_by": { "type": "string" },
        "submission_type": { "type": "string", "enum": ["individual","vendor","research"] },
        "date": { "type": "string", "format": "date" },
        "reproduce_script": { "type": "string" },
        "env_info_file": { "type": "string" },
        "log_file": { "type": ["string","null"] },
        "samples_file": { "type": ["string","null"] },
        "notes": { "type": ["string","null"] },
        "benchmark_start_time": {
          "type": ["string","null"],
          "description": "ISO 8601 timestamp when benchmark started (after model load)."
        },
        "benchmark_end_time": {
          "type": ["string","null"],
          "description": "ISO 8601 timestamp when benchmark completed."
        },
        "benchmark_elapsed_minutes": {
          "type": ["number","null"],
          "description": "Total benchmark duration in minutes, excluding model load time."
        },
        "model_load_seconds": {
          "type": ["number","null"],
          "description": "Time in seconds to load model weights into GPU memory."
        },
        "scenario_dirs": {
          "type": ["object","null"],
          "description": "Paths to individual scenario output directories. Only present for suite-level submissions.",
          "additionalProperties": {"type": "string"}
        },
        "benchmark_elapsed_minutes_note": {
          "type": ["string","null"]
        },
        "chip_count_dirs": {
          "type": ["object","null"],
          "description": "Paths to per-chip-count output directories. Only present for Suite E submissions.",
          "additionalProperties": {"type": "string"}
        },
        "precision_dirs": {
          "type": ["object","null"],
          "description": "Paths to per-precision output directories. Only present for Suite C submissions.",
          "additionalProperties": {"type": "string"}
        }
      }
    }

  }
}
