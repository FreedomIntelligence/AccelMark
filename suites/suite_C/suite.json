  "online_qps_levels": [5, 10, 25, 50],
  "online_sla_ttft_ms": 500,
  "online_request_count": 500,

  "sustained_concurrency": 8,
  "duration_minutes": 30,
  "warmup_minutes": 2,
  "sample_interval_seconds": 60
}
