    }
  },

  "precision_levels": ["BF16", "FP8", "W8A8", "W8A16", "W4A16"],

  "accuracy_thresholds": {
    "BF16":  0.03,
    "FP8":   0.03,
    "W8A8":  0.04,
    "W8A16": 0.03,
    "W4A16": 0.05
  },

  "scenarios": {
    "default": ["accuracy", "offline"],
    "extra":   ["online", "sustained"]
